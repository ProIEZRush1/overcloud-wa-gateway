# Overcloud WhatsApp gateway
PORT=8088

# Shared secret — must match the panel's WA_GATEWAY_TOKEN.
GATEWAY_TOKEN=change-me-to-a-long-random-string

# Where the Laravel panel receives inbound webhooks.
LARAVEL_URL=http://overcloud.test

# Storage (auth state, downloaded media, session list). Defaults under ./storage.
# AUTH_DIR=./storage/auth
# MEDIA_DIR=./storage/media
# SESSIONS_FILE=./storage/sessions.json

# Inline media up to this size (bytes) into the inbound webhook; larger stays on disk only.
MAX_INLINE_MEDIA=16777216

LOG_LEVEL=info
